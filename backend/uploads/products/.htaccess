# Dossier d'images uploadées : servir les fichiers statiques uniquement,
# jamais exécuter de PHP ici (sécurité upload)
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps)$">
    Require all denied
</FilesMatch>

# Autoriser l'affichage cross-origin des images (frontend Vercel)
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set Cache-Control "public, max-age=2592000"
</IfModule>
